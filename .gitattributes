# Text/source files — always normalized to LF, both in the repo and on checkout,
# regardless of either machine's core.autocrlf so Linux/Windows never disagree.
* text=auto eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cs text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.uproject text eol=lf
*.uplugin text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf
